# =============================================================================
# .env.example — environment variable defaults for docker-compose
#
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# The .env file is read automatically by `docker compose`.
# Never commit a .env file containing real secrets to source control.
# =============================================================================

# --- Database ----------------------------------------------------------------
DB_USERNAME=admin
DB_PASSWORD=admin
DB_NAME=store

# Host port PostgreSQL is exposed on (avoids clash with a local Postgres on 5432)
DB_HOST_PORT=5433

# HikariCP connection pool size
DB_POOL_SIZE=10

# --- Application -------------------------------------------------------------
APP_PORT=8080

# --- Logging -----------------------------------------------------------------
# Set to INFO to silence Hibernate SQL query logging
HIBERNATE_SQL_LOG_LEVEL=DEBUG

