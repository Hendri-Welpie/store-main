{
  "info": {
    "name": "Store API",
    "description": "Complete test suite for the Store API.\n\nRun the folders **in order** (1 → 2 → 3) so that the IDs created in the Customer and Product setup steps are available as collection variables when the Order tests run.\n\nCollection variables set automatically by tests:\n- `customerId`  — set by \"Create Customer\"\n- `product1Id`  — set by \"Create Product 1\"\n- `product2Id`  — set by \"Create Product 2\"\n- `orderId`     — set by \"Create Order\"\n\nChange `baseUrl` in *Variables* if your server runs on a different host/port.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "",
      "type": "string"
    },
    {
      "key": "product1Id",
      "value": "",
      "type": "string"
    },
    {
      "key": "product2Id",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Customers",
      "description": "Customer management — create, list, and search. Run this folder first so that `customerId` is available for the Orders folder.",
      "item": [
        {
          "name": "Create Customer (Happy Path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201 Created\", () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has X-Trace-Id header\", () => {",
                  "    pm.response.to.have.header(\"X-Trace-Id\");",
                  "});",
                  "",
                  "pm.test(\"Response body has id and name\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a(\"number\");",
                  "    pm.expect(body.name).to.eql(\"Alice Smith\");",
                  "    pm.expect(body.orders).to.be.an(\"array\");",
                  "    // Store the id for later requests",
                  "    pm.collectionVariables.set(\"customerId\", body.id);",
                  "    console.log(\"Saved customerId:\", body.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Smith\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customer",
              "host": ["{{baseUrl}}"],
              "path": ["customer"]
            }
          }
        },
        {
          "name": "Create Customer — Blank Name (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 400 Bad Request\", () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Response has X-Trace-Id header\", () => {",
                  "    pm.response.to.have.header(\"X-Trace-Id\");",
                  "});",
                  "",
                  "pm.test(\"Error body has status, error, message, timestamp\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql(400);",
                  "    pm.expect(body.error).to.be.a(\"string\");",
                  "    pm.expect(body.message).to.be.a(\"string\");",
                  "    pm.expect(body.timestamp).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"Error message mentions 'name'\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message.toLowerCase()).to.include(\"name\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customer",
              "host": ["{{baseUrl}}"],
              "path": ["customer"]
            }
          }
        },
