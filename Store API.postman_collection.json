                  "pm.test(\"Server echoes the client-supplied X-Trace-Id\", () => {",
                  "    const sent = pm.request.headers.get(\"X-Trace-Id\");",
                  "    const received = pm.response.headers.get(\"X-Trace-Id\");",
                  "    pm.expect(received).to.eql(sent);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
