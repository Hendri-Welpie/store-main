    {
      "name": "3. Orders",
      "description": "Order lifecycle — create and query. Depends on `customerId`, `product1Id`, `product2Id` being set by the previous folders.",
      "item": [
        {
          "name": "Create Order — With Two Products (Happy Path)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Guard: warn if upstream IDs were never set",
                  "const cid = pm.collectionVariables.get(\"customerId\");",
                  "const p1  = pm.collectionVariables.get(\"product1Id\");",
                  "const p2  = pm.collectionVariables.get(\"product2Id\");",
                  "if (!cid || !p1 || !p2) {",
                  "    console.warn(\"customerId / product1Id / product2Id not set — run folders 1 and 2 first!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201 Created\", () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has X-Trace-Id header\", () => {",
                  "    pm.response.to.have.header(\"X-Trace-Id\");",
                  "});",
                  "",
                  "pm.test(\"Response body has id, description, customer, products\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a(\"number\");",
                  "    pm.expect(body.description).to.eql(\"Office supplies for Q2\");",
                  "    pm.expect(body.customer).to.be.an(\"object\");",
                  "    pm.expect(body.customer.id).to.eql(parseInt(pm.collectionVariables.get(\"customerId\")));",
                  "    pm.expect(body.products).to.be.an(\"array\");",
                  "    pm.expect(body.products.length).to.eql(2);",
                  "    pm.collectionVariables.set(\"orderId\", body.id);",
                  "    console.log(\"Saved orderId:\", body.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"description\": \"Office supplies for Q2\",\n  \"productIds\": [{{product1Id}}, {{product2Id}}]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/order",
              "host": ["{{baseUrl}}"],
              "path": ["order"]
            }
          }
        },
        {
          "name": "Create Order — No Products (Happy Path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201 Created\", () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Products list is empty\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.products).to.be.an(\"array\");",
                  "    pm.expect(body.products.length).to.eql(0);",
                  "});"
